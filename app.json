{
  "expo": {
    "name": "migchat",
    "slug": "migme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/migme_logo.png",
    "scheme": "migchat",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mig33.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/migme_logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mig33.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/migme_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/migme_logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3d22fe9-f078-41f4-950a-04064ac522b9"
      }
    }
  }
}
